{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "just-us-race-room",
  "main": "src/index.js",
  "compatibility_date": "2026-07-01",
  "durable_objects": {
    "bindings": [
      { "name": "RACE_ROOM", "class_name": "RaceRoom" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["RaceRoom"] }
  ]
}
